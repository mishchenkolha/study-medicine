{
  "kind": "collectionType",
  "collectionName": "user_transactions",
  "info": {
    "singularName": "user-transaction",
    "pluralName": "user-transactions",
    "displayName": "user_transaction"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "course": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::course.course"
    },
    "amount": {
      "type": "decimal"
    },
    "transaction_id": {
      "type": "string",
      "unique": true
    },
    "payment_status": {
      "type": "enumeration",
      "enum": [
        "paid",
        "refunded",
        "failed"
      ]
    }
  }
}
