{
  "version": 1,
  "functions": {
    "/_middleware": {
      "runtime": "nodejs",
      "matchers": [
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?(?:\\/((?!_next|images\\/|api\\/|favicon.ico|static\\/).*))(\\.json)?[\\/#\\?]?$",
          "originalSource": "/((?!_next|images/|api/|favicon.ico|static/).*)"
        }
      ]
    }
  }
}